{
  "name": "agloom-cli",
  "version": "0.1.1",
  "description": "agloom CLI — terminal client for the agloom runtime (AGP, streaming-first; interactive TUI + direct mode)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agloom": "./dist/index.js",
    "agloom-completions": "./scripts/agloom-completions.mjs"
  },
  "files": [
    "dist",
    "prompts",
    "completions",
    "scripts/agloom-completions.mjs",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest --config jest.config.mjs && node --no-warnings --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.ink.config.mjs",
    "test:watch": "jest --config jest.config.mjs --watch",
    "test:ink": "node --no-warnings --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.ink.config.mjs"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "cli-highlight": "^2.1.11",
    "commander": "14.0.3",
    "ink": "7.0.2",
    "ink-text-input": "6.0.0",
    "react": "19.2.6",
    "strip-ansi": "7.2.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "keywords": [
    "agloom",
    "agp",
    "ai",
    "cli",
    "ink",
    "react",
    "terminal"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/HELLOMEDHIRA/agloom/tree/main/agloom_cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HELLOMEDHIRA/agloom.git",
    "directory": "agloom_cli"
  },
  "bugs": {
    "url": "https://github.com/HELLOMEDHIRA/agloom/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
